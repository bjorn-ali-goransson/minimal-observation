# --- Minimal Observation config (copy to .env) ---

# API key required to ingest (OTLP) and to query. Send as `x-api-key` or `Authorization: ApiKey <key>`.
MO_API_KEY=dev-secret-key

# HTTP port for the combined ingest + query + UI server.
MO_PORT=4318

# Where the hot SQLite file + local frozen data / S3 cache live.
MO_DATA_DIR=./data

# Retention in days (frozen days older than this are dropped; hot rows swept).
MO_RETENTION_DAYS=7

# Micro-batch flush: max buffered spans OR max ms before a flush to the hot store.
MO_FLUSH_MAX_ROWS=2000
MO_FLUSH_MAX_MS=2000

# Frozen tier backend: "local" (per-day SQLite files under MO_DATA_DIR/cold) or "s3" (MinIO / real S3).
MO_COLD_KIND=local

# Sliding idle eviction (ms) for frozen days loaded from the frozen store.
MO_COLD_IDLE_MS=3600000

# --- S3 frozen tier (only when MO_COLD_KIND=s3) ---
MO_S3_ENDPOINT=http://minio:9000
MO_S3_REGION=us-east-1
MO_S3_BUCKET=mo-spans
MO_S3_ACCESS_KEY=minioadmin
MO_S3_SECRET_KEY=minioadmin
MO_S3_URL_STYLE=path

# --- AI investigator (optional; agent endpoints 503 without a key) ---
ANTHROPIC_API_KEY=
MO_AGENT_MODEL=claude-opus-4-8
# Override the Anthropic API base URL (e.g. a local mock). Leave blank for the real API.
ANTHROPIC_BASE_URL=
