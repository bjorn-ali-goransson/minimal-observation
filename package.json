{
  "name": "minimal-observation",
  "version": "0.1.0",
  "private": true,
  "description": "Feather-light distributed-tracing APM: OpenTelemetry ingest, DuckDB tiered storage, React UI, AI investigator.",
  "packageManager": "pnpm@10.33.0",
  "engines": { "node": ">=22" },
  "pnpm": { "onlyBuiltDependencies": ["esbuild"] },
  "scripts": {
    "build": "pnpm -r build",
    "build:ui": "pnpm --filter @mo/ui build",
    "dev:server": "pnpm --filter @mo/server dev",
    "dev:ui": "pnpm --filter @mo/ui dev",
    "start": "pnpm --filter @mo/server start",
    "seed": "pnpm --filter @mo/server seed",
    "sample": "pnpm --filter @mo/sample start",
    "typecheck": "pnpm -r typecheck",
    "e2e": "pnpm --filter @mo/e2e test"
  }
}
